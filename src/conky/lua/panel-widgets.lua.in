-- panel-widgets.lua — full-cairo rendering of the alarme-conky panel.
--
-- Every visible pixel (banner, divider, KPI rings, habit rings,
-- calendar grid, section headers, task / done / inbox / note / error
-- rows) is drawn by this Lua script through cairo. conky.text is now
-- a single ${voffset} that reserves panel height; we read state.json
-- ourselves and lay everything out vertically from y=0.
--
-- The motivation is a single render pipeline. The previous hybrid
-- (some sections via Pango through conky's text engine, the widget
-- sections via cairo here) produced visually inconsistent labels at
-- the same nominal font size, because the two engines hint and space
-- glyphs differently. Going all-cairo gives identical rendering for
-- every label and row in the panel.
--
-- All constants are substituted by home.nix at build time so the
-- script reads nothing from env or config at draw time.

require('cairo')

-- ── injected by home.nix ────────────────────────────────────────────────────

local STATE        = '@STATE@'
local PANEL_W      = @PANEL_W@
local PANEL_H      = @PANEL_H@
local FONT_FAM     = '@FONT_FAMILY@'
local BODY_SIZE    = @BODY_SIZE@
local HEADER_SIZE  = @HEADER_SIZE@
local NF_FONT      = 'FiraCode Nerd Font Mono'

local PALETTE = {
  bg       = '@BG@',
  fg       = '@FG@',
  muted    = '@MUTED@',
  divider  = '@DIVIDER@',
  section  = '@SECTION@',
  counter  = '@COUNTER@',
  highlight= '@HIGHLIGHT@',
  alert    = '@ALERT@',
  ok       = '@OK@',
  accent   = '@ACCENT@',
}

-- Nerd Font Font-Awesome codepoints used by section headers + banner.
-- Defined as Lua \u{xxxx} escapes (Lua 5.3+) so the source stays
-- editor-paste safe (no raw PUA chars in the file).
local NF = {
  bolt    = '\u{f0e7}',
  refresh = '\u{f021}',
  fire    = '\u{f06d}',
  cal     = '\u{f073}',
  today   = '\u{f017}',
  check   = '\u{f058}',
  inbox   = '\u{f01c}',
  note    = '\u{f0f6}',
  warn    = '\u{f071}',
}

-- Per-row sigils. Plain unicode (not PUA) so they render in the main
-- font family without a Nerd Font face switch.
local SIG_BULLET = '\u{2022}'  -- •
local SIG_CHECK  = '\u{2713}'  -- ✓

-- ── colour helpers ─────────────────────────────────────────────────────────

local function hex(h)
  return tonumber(h:sub(1, 2), 16) / 255,
         tonumber(h:sub(3, 4), 16) / 255,
         tonumber(h:sub(5, 6), 16) / 255
end

local function rgba(cr, h, a)
  local r, g, b = hex(h)
  cairo_set_source_rgba(cr, r, g, b, a or 1.0)
end

-- ── text extents + drawing helpers ─────────────────────────────────────────

local function te(cr, s)
  local ext = cairo_text_extents_t:create()
  tolua.takeownership(ext)
  cairo_text_extents(cr, s, ext)
  return ext
end

local function set_face(cr, family, weight, size)
  cairo_select_font_face(cr, family, 0, weight or 0)
  cairo_set_font_size(cr, size)
end

-- Draw at (x, y) with the top of the glyph bounding box anchored at y.
-- Returns the advance width so callers can chain subsequent draws on
-- the same baseline.
local function show_top(cr, x, y, s, family, weight, size)
  set_face(cr, family, weight, size)
  local e = te(cr, s)
  cairo_move_to(cr, x - e.x_bearing, y - e.y_bearing)
  cairo_show_text(cr, s)
  return e.x_advance
end

-- Draw centred at (cx, cy) on both axes.
local function show_centred(cr, cx, cy, s, family, weight, size)
  set_face(cr, family, weight, size)
  local e = te(cr, s)
  cairo_move_to(cr, cx - e.width / 2 - e.x_bearing,
                    cy - e.y_bearing - e.height / 2)
  cairo_show_text(cr, s)
end

-- Iterate a UTF-8 string char by char. The pattern matches one
-- "starter" byte (0x00–0x7F or 0xC2–0xF4) followed by any number of
-- continuation bytes (0x80–0xBF). Good enough for our task titles.
local function utf8_chars(s)
  local out = {}
  for ch in s:gmatch('[%z\1-\127\194-\244][\128-\191]*') do
    table.insert(out, ch)
  end
  return out
end

-- Truncate ``s`` to fit ``max_w`` pixels at (family/weight/size),
-- appending an ellipsis when truncated.
local function truncate(cr, s, max_w, family, weight, size)
  set_face(cr, family, weight, size)
  local full = te(cr, s)
  if full.x_advance <= max_w then return s end
  local ell = '\u{2026}'
  local chars = utf8_chars(s)
  -- Greedy shrink: drop one char at a time from the tail until the
  -- ellipsised string fits. O(n) on title length, fine at 1Hz.
  for n = #chars - 1, 1, -1 do
    local cand = table.concat(chars, '', 1, n) .. ell
    if te(cr, cand).x_advance <= max_w then return cand end
  end
  return ell
end

-- ── JSON loading (state.json) ──────────────────────────────────────────────
--
-- Cache the parsed state by raw-content equality. The fetcher
-- rewrites state.json every poll cycle (~30s), but our draw hook
-- fires every second — so most frames we'd otherwise re-parse the
-- same JSON we parsed last frame. The parse is by far the most
-- expensive thing in the hot path; skipping it when the content is
-- byte-identical cuts the per-frame cost dramatically and removes
-- the visible "I-took-too-long" flicker.

local _decode  -- forward decl so load_state can pcall it
local _cached_raw   = nil
local _cached_state = {}

local function load_state()
  local f = io.open(STATE, 'r')
  if not f then return _cached_state end
  local raw = f:read('*a')
  f:close()
  if raw == _cached_raw then return _cached_state end
  _cached_raw = raw
  local ok, decoded = pcall(_decode, raw)
  _cached_state = ok and (decoded or {}) or {}
  return _cached_state
end

-- Minimal JSON decoder — handles every shape the fetcher emits.
_decode = function(s)
  local pos = 1
  local function ws()
    while pos <= #s and s:sub(pos, pos):match('[%s\n\r\t]') do
      pos = pos + 1
    end
  end
  local function val()
    ws()
    local c = s:sub(pos, pos)
    if c == '"' then
      local start = pos + 1
      pos = pos + 1
      while pos <= #s do
        local ch = s:sub(pos, pos)
        if ch == '\\' then pos = pos + 2
        elseif ch == '"' then
          local raw = s:sub(start, pos - 1)
          pos = pos + 1
          raw = raw:gsub('\\"', '"'):gsub('\\\\', '\\')
                   :gsub('\\n', '\n'):gsub('\\t', '\t')
          return raw
        else pos = pos + 1 end
      end
    elseif c == '{' then
      local t = {}; pos = pos + 1; ws()
      if s:sub(pos, pos) == '}' then pos = pos + 1; return t end
      while true do
        ws()
        local k = val()
        ws(); pos = pos + 1  -- skip ':'
        local v = val(); t[k] = v
        ws()
        local nxt = s:sub(pos, pos)
        pos = pos + 1
        if nxt == '}' then return t end
      end
    elseif c == '[' then
      local t = {}; pos = pos + 1; ws()
      if s:sub(pos, pos) == ']' then pos = pos + 1; return t end
      while true do
        local v = val(); table.insert(t, v); ws()
        local nxt = s:sub(pos, pos)
        pos = pos + 1
        if nxt == ']' then return t end
      end
    elseif c == 't' then pos = pos + 4; return true
    elseif c == 'f' then pos = pos + 5; return false
    elseif c == 'n' then pos = pos + 4; return nil
    else
      local start = pos
      while pos <= #s and s:sub(pos, pos):match('[%d%.eE%+%-]') do
        pos = pos + 1
      end
      return tonumber(s:sub(start, pos - 1))
    end
  end
  return val()
end

-- ── widget: gradient divider ───────────────────────────────────────────────

local function draw_divider(cr, y)
  local x0, x1 = 12, PANEL_W - 12
  local pat = cairo_pattern_create_linear(x0, y, x1, y)
  local r, g, b = hex(PALETTE.divider)
  cairo_pattern_add_color_stop_rgba(pat, 0,    r, g, b, 0)
  cairo_pattern_add_color_stop_rgba(pat, 0.5,  r, g, b, 0.7)
  cairo_pattern_add_color_stop_rgba(pat, 1,    r, g, b, 0)
  cairo_set_source(cr, pat)
  cairo_set_line_width(cr, 1)
  cairo_move_to(cr, x0, y)
  cairo_line_to(cr, x1, y)
  cairo_stroke(cr)
  cairo_pattern_destroy(pat)
end

-- ── widget: section header (icon + label, section colour, bold) ────────────

local function draw_section_header(cr, x, y, icon, label)
  rgba(cr, PALETTE.section, 1.0)
  local w = show_top(cr, x, y, icon, NF_FONT, 1, HEADER_SIZE)
  show_top(cr, x + w + 6, y, ' ' .. label, FONT_FAM, 1, HEADER_SIZE)
end

-- ── widget: banner (title left, freshness badge right) ─────────────────────

local function age_label(meta)
  local epoch = tonumber(meta.fetched_at_epoch) or 0
  if epoch == 0 then return PALETTE.muted, 'no data' end
  local diff = os.time() - epoch
  if diff < 60  then return PALETTE.ok,        diff .. 's ago' end
  if diff < 300 then return PALETTE.highlight, math.floor(diff/60) .. 'm ago' end
  return PALETTE.alert, math.floor(diff/60) .. 'm ago'
end

local function draw_banner(cr, y, meta)
  -- Left: bolt icon + "Alarme"
  draw_section_header(cr, 12, y, NF.bolt, 'Alarme')

  -- Right: refresh icon + age, body size, age-coloured. We anchor on
  -- the same top-y as the header so the two read as one row even
  -- though they use different font sizes.
  local color, label = age_label(meta)
  rgba(cr, color, 1.0)
  set_face(cr, FONT_FAM, 0, BODY_SIZE)
  local lw = te(cr, label).x_advance
  set_face(cr, NF_FONT, 0, BODY_SIZE)
  local iw = te(cr, NF.refresh).x_advance
  -- Right-align: label hugs PANEL_W - 12, icon to its left
  local row_y = y + (HEADER_SIZE - BODY_SIZE)  -- align baselines
  local age_x = PANEL_W - 12 - lw
  local ico_x = age_x - iw - 4
  show_top(cr, ico_x, row_y, NF.refresh, NF_FONT, 0, BODY_SIZE)
  show_top(cr, age_x, row_y, label, FONT_FAM, 0, BODY_SIZE)
end

-- ── widget: KPI ring tile (count + soft-cap fill + sub-label) ──────────────

local KPI_R          = 32
local KPI_T          = 5
local KPI_LABEL_GAP  = 14

local function draw_kpi_ring(cr, cx, cy, count, label, accent, soft_cap)
  soft_cap = soft_cap or 10
  local ratio = math.min(count / soft_cap, 1.0)
  local over = count > soft_cap

  -- Track ring (new_sub_path resets cairo's current point so the next
  -- arc isn't connected by a stray "tail" line from the previous one)
  rgba(cr, PALETTE.muted, 0.30)
  cairo_set_line_width(cr, KPI_T)
  cairo_new_sub_path(cr)
  cairo_arc(cr, cx, cy, KPI_R, 0, 2 * math.pi)
  cairo_stroke(cr)

  if count > 0 then
    rgba(cr, over and PALETTE.alert or accent, 1.0)
    cairo_set_line_width(cr, KPI_T)
    cairo_set_line_cap(cr, 1)
    cairo_new_sub_path(cr)
    local start = -math.pi / 2
    cairo_arc(cr, cx, cy, KPI_R, start, start + 2 * math.pi * ratio)
    cairo_stroke(cr)
  end

  -- Centre digit
  rgba(cr, PALETTE.fg, 1.0)
  show_centred(cr, cx, cy, tostring(count), FONT_FAM, 1, 28)

  -- Sub-label below — letter-spaced uppercase ("SmallCaps")
  set_face(cr, FONT_FAM, 1, 10)
  local upper = label:upper()
  local total_w = 0
  for ch in upper:gmatch('.') do
    total_w = total_w + te(cr, ch).x_advance + 1.8
  end
  rgba(cr, PALETTE.muted, 1.0)
  local cur = cx - total_w / 2
  local ly = cy + KPI_R + KPI_LABEL_GAP
  for ch in upper:gmatch('.') do
    local e = te(cr, ch)
    cairo_move_to(cr, cur - e.x_bearing, ly - e.y_bearing)
    cairo_show_text(cr, ch)
    cur = cur + e.x_advance + 1.8
  end
end

local function draw_kpi_row(cr, y_top, counters)
  local cy = y_top + KPI_R
  local cs = { PANEL_W / 6, PANEL_W / 2, 5 * PANEL_W / 6 }
  draw_kpi_ring(cr, cs[1], cy, counters.overdue   or 0, 'overdue', PALETTE.alert,     5)
  draw_kpi_ring(cr, cs[2], cy, counters.today     or 0, 'today',   PALETTE.highlight, 8)
  draw_kpi_ring(cr, cs[3], cy, counters.this_week or 0, 'week',    PALETTE.section,  15)
end

-- ── widget: habit rings ────────────────────────────────────────────────────

local HABIT_R  = 14
local HABIT_T  = 4
local HABIT_SP = 38

local function draw_habit_ring(cr, cx, cy, habit)
  local count = tonumber(habit.count) or 0
  local target = tonumber(habit.target_count) or 1
  local ratio = math.min(count / target, 1.0)

  rgba(cr, PALETTE.muted, 0.25)
  cairo_set_line_width(cr, HABIT_T)
  cairo_new_sub_path(cr)
  cairo_arc(cr, cx, cy, HABIT_R, 0, 2 * math.pi)
  cairo_stroke(cr)

  if ratio > 0 then
    rgba(cr, PALETTE.ok, 1.0)
    cairo_set_line_width(cr, HABIT_T)
    cairo_set_line_cap(cr, 1)
    cairo_new_sub_path(cr)
    cairo_arc(cr, cx, cy, HABIT_R, -math.pi / 2,
              -math.pi / 2 + 2 * math.pi * ratio)
    cairo_stroke(cr)
  end

  if target > 1 then
    rgba(cr, PALETTE.fg, 0.9)
    show_centred(cr, cx, cy, tostring(count), FONT_FAM, 1, 12)
  end
end

local function draw_habits(cr, y_top, habits)
  local n = math.min(#habits, 7)
  local total_w = (n - 1) * HABIT_SP + 2 * HABIT_R
  local start_x = (PANEL_W - total_w) / 2 + HABIT_R
  local cy = y_top + HABIT_R
  for i = 1, n do
    local cx = start_x + (i - 1) * HABIT_SP
    draw_habit_ring(cr, cx, cy, habits[i])
  end
end

-- ── widget: calendar grid (month heat-map) ─────────────────────────────────

local CAL_CELL_W = (PANEL_W - 24) / 7
local CAL_CELL_H = 28
local CAL_WK_H   = 20

local function busy_n(busy, day)
  if not busy then return 0 end
  return tonumber(busy[tostring(day)] or busy[day]) or 0
end

local function draw_calendar(cr, y_top, cal)
  local today = tonumber(cal.today) or 0
  local weeks = cal.weeks or {}
  local busy  = cal.busy or {}

  -- Weekday header row
  local wk_y = y_top + CAL_WK_H / 2
  local labels = { 'M', 'T', 'W', 'T', 'F', 'S', 'S' }
  rgba(cr, PALETTE.muted, 0.85)
  for i, lbl in ipairs(labels) do
    local cx = 12 + (i - 0.5) * CAL_CELL_W
    show_centred(cr, cx, wk_y, lbl, FONT_FAM, 1, 11)
  end

  -- Day grid
  local grid_y = y_top + CAL_WK_H
  for row_i, week in ipairs(weeks) do
    for col_i, day in ipairs(week) do
      if day > 0 then
        local cx = 12 + (col_i - 0.5) * CAL_CELL_W
        local cy = grid_y + (row_i - 0.5) * CAL_CELL_H
        local is_today = (day == today)
        local n = busy_n(busy, day)
        local is_past = day < today

        if is_today then
          rgba(cr, PALETTE.accent, 1.0)
          cairo_new_sub_path(cr)
          cairo_arc(cr, cx, cy, 12, 0, 2 * math.pi)
          cairo_fill(cr)
          rgba(cr, PALETTE.bg, 1.0)
        elseif n >= 3 then
          rgba(cr, PALETTE.alert, 0.95)
        elseif n >= 1 then
          rgba(cr, PALETTE.highlight, 0.95)
        elseif is_past then
          rgba(cr, PALETTE.muted, 0.40)
        else
          rgba(cr, PALETTE.fg, 0.80)
        end

        show_centred(cr, cx, cy, tostring(day), FONT_FAM, 0, 13)

        if n >= 1 and not is_today then
          rgba(cr, PALETTE.highlight, 0.9)
          cairo_new_sub_path(cr)
          cairo_arc(cr, cx, cy + 10, 1.8, 0, 2 * math.pi)
          cairo_fill(cr)
        end
      end
    end
  end
end

-- ── list rows (task / done / inbox / notes) ────────────────────────────────

local LIST_X    = 24                 -- indent under section header
local ROW_H     = BODY_SIZE + 6      -- per-row vertical step
local SIGIL_GAP = 8                  -- space between sigil and title

-- Draw a list row: <sigil> <title …> [<right-aligned time>]
local function draw_list_row(cr, y, title, sigil, sigil_color, title_color, right_text)
  -- Sigil
  rgba(cr, sigil_color, 1.0)
  local sw = show_top(cr, LIST_X, y, sigil, FONT_FAM, 0, BODY_SIZE)

  -- Compute right-text width so the title can be truncated to leave
  -- room. Empty string → no reservation.
  local right_w = 0
  if right_text and right_text ~= '' then
    set_face(cr, FONT_FAM, 0, BODY_SIZE)
    right_w = te(cr, right_text).x_advance + 8
  end

  -- Title with truncation
  local title_x = LIST_X + sw + SIGIL_GAP
  local max_title_w = PANEL_W - 12 - title_x - right_w
  local trunc = truncate(cr, title or '', max_title_w, FONT_FAM, 0, BODY_SIZE)
  rgba(cr, title_color, 1.0)
  show_top(cr, title_x, y, trunc, FONT_FAM, 0, BODY_SIZE)

  -- Right-aligned text (e.g. scheduled time)
  if right_w > 0 then
    rgba(cr, PALETTE.muted, 1.0)
    set_face(cr, FONT_FAM, 0, BODY_SIZE)
    local e = te(cr, right_text)
    local rx = PANEL_W - 12 - e.x_advance
    cairo_move_to(cr, rx - e.x_bearing, y - e.y_bearing)
    cairo_show_text(cr, right_text)
  end
end

local function draw_muted_row(cr, y, txt)
  rgba(cr, PALETTE.muted, 0.85)
  show_top(cr, LIST_X, y, txt, FONT_FAM, 0, BODY_SIZE)
end

local function draw_error_row(cr, y, err)
  rgba(cr, PALETTE.alert, 1.0)
  local w = show_top(cr, 12, y, NF.warn, NF_FONT, 0, BODY_SIZE)
  show_top(cr, 12 + w + 6, y, ' ' .. err, FONT_FAM, 0, BODY_SIZE)
end

-- ── main draw hook ─────────────────────────────────────────────────────────
--
-- Wayland conky runs in single-buffer mode (the layer-shell surface
-- IS the drawing buffer — there's no separate back buffer to swap).
-- That means anything that draws between conky's per-frame clear and
-- the next compositor frame callback is visible on screen, including
-- the half-drawn intermediate state of our cairo paths. The user
-- perceives that as flicker on every redraw.
--
-- The fix is to render everything onto an in-memory ARGB32 surface
-- first, then ``cairo_paint`` the whole image onto conky's surface
-- in one shot. The blit is a single rectangular memcpy from cairo's
-- perspective, so there's no intermediate "half-drawn" frame.

function conky_draw_panel()
  if conky_window == nil then return end
  local cs = conky_surface()
  if cs == nil then return end

  -- Offscreen ARGB32 surface — same size as the panel. We always
  -- (re)create it per frame; cairo image surfaces are cheap.
  local off = cairo_image_surface_create(CAIRO_FORMAT_ARGB32, PANEL_W, PANEL_H)
  local cr = cairo_create(off)

  local ok, st = pcall(load_state)
  st = (ok and st) or {}
  local data = st.data or {}
  local meta = st.meta or {}

  -- Banner row (title + age)
  draw_banner(cr, 8, meta)
  -- Divider just below the banner row baseline
  draw_divider(cr, 8 + HEADER_SIZE + 14)

  -- KPI rings tile row
  local KPI_TOP = 8 + HEADER_SIZE + 14 + 14
  draw_kpi_row(cr, KPI_TOP, data.counters or {})
  -- KPI block consumes 2*KPI_R + sub-label gap + sub-label height
  local KPI_BOTTOM = KPI_TOP + KPI_R * 2 + KPI_LABEL_GAP + 12

  local y = KPI_BOTTOM + 18  -- gap below KPI tile

  -- Habits — only if at least one habit exists
  local habits = data.habits_today or {}
  if #habits > 0 then
    draw_section_header(cr, 12, y, NF.fire, 'Habits')
    y = y + HEADER_SIZE + 12
    draw_habits(cr, y, habits)
    y = y + HABIT_R * 2 + 16
  end

  -- Calendar — always shown
  draw_section_header(cr, 12, y, NF.cal, 'Calendar')
  y = y + HEADER_SIZE + 12
  local cal = data.calendar_struct or {}
  draw_calendar(cr, y, cal)
  local weeks = cal.weeks or {}
  y = y + CAL_WK_H + #weeks * CAL_CELL_H + 16

  -- Today
  draw_section_header(cr, 12, y, NF.today, 'Today')
  y = y + HEADER_SIZE + 8
  local today_tasks = data.today_tasks or {}
  if #today_tasks == 0 then
    draw_muted_row(cr, y, '(nothing scheduled)')
    y = y + ROW_H
  else
    for i = 1, math.min(#today_tasks, 8) do
      local t = today_tasks[i] or {}
      draw_list_row(cr, y, t.title or '',
                    SIG_BULLET, PALETTE.muted, PALETTE.fg,
                    t.scheduled_time)
      y = y + ROW_H
    end
  end
  y = y + 8

  -- Done today
  local done = data.done_today_tasks or {}
  if #done > 0 then
    draw_section_header(cr, 12, y, NF.check, 'Done today')
    y = y + HEADER_SIZE + 8
    local shown = math.min(#done, 4)
    for i = 1, shown do
      local t = done[i] or {}
      draw_list_row(cr, y, t.title or '',
                    SIG_CHECK, PALETTE.ok, PALETTE.fg, nil)
      y = y + ROW_H
    end
    local more = (data.done_today_count or 0) - shown
    if more > 0 then
      draw_muted_row(cr, y, ('+ %d more'):format(more))
      y = y + ROW_H
    end
    y = y + 8
  end

  -- Inbox
  local inbox = data.inbox_tasks or {}
  if (data.inbox_count or 0) > 0 then
    draw_section_header(cr, 12, y, NF.inbox, 'Inbox')
    y = y + HEADER_SIZE + 8
    local shown = math.min(#inbox, 4)
    for i = 1, shown do
      local t = inbox[i] or {}
      draw_list_row(cr, y, t.title or '',
                    SIG_BULLET, PALETTE.muted, PALETTE.fg, nil)
      y = y + ROW_H
    end
    local more = data.inbox_count - shown
    if more > 0 then
      draw_muted_row(cr, y, ('+ %d more'):format(more))
      y = y + ROW_H
    end
    y = y + 8
  end

  -- Notes (recent)
  local notes = data.notes_recent or {}
  if #notes > 0 then
    draw_section_header(cr, 12, y, NF.note, 'Notes')
    y = y + HEADER_SIZE + 8
    for i = 1, math.min(#notes, 3) do
      local n = notes[i] or {}
      draw_list_row(cr, y, n.title or '',
                    SIG_BULLET, PALETTE.muted, PALETTE.fg, nil)
      y = y + ROW_H
    end
    y = y + 8
  end

  -- Error banner — last line, alert-coloured
  local err = meta.last_error
  if err and err ~= '' then
    draw_error_row(cr, y, err)
  end

  cairo_destroy(cr)

  -- One-shot blit of the fully-drawn offscreen surface onto conky's
  -- real (visible) surface. CAIRO_OPERATOR_SOURCE — not the default
  -- OVER — so the destination is *replaced* by our pixels rather
  -- than alpha-blended on top of whatever conky already painted;
  -- this preserves our transparent regions (so the wallpaper shows
  -- through unmodified) instead of double-stacking the bg colour.
  local outr = cairo_create(cs)
  cairo_set_operator(outr, CAIRO_OPERATOR_SOURCE)
  cairo_set_source_surface(outr, off, 0, 0)
  cairo_paint(outr)
  cairo_destroy(outr)
  cairo_surface_destroy(off)
end
